  "gpos": [
    {
      "name": "DC303 Baseline Workstation Policy",
      "id": null,
      "backupPath": null,
      "description": "Baseline security hardening for all DC303 domain workstations"
    },
    {
      "name": "DC303 Baseline Server Policy",
      "id": null,
      "backupPath": null,
      "description": "Baseline security hardening for all DC303 domain servers"
    },
    {
      "name": "DC303 Domain Branding - Logon Screen",
      "id": null,
      "backupPath": null,
      "description": "DC303 logon and lock screen branding for all domain systems",
      "settings": {
        "computer": [
          {
            "key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Personalization",
            "valueName": "LockScreenImage",
            "value": "\\\\dc303.cdx.lab\\NETLOGON\\Images\\dc303-login-banner.jpg",
            "type": "String"
          },
          {
            "key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Personalization",
            "valueName": "NoChangingLockScreen",
            "value": 1,
            "type": "DWord"
          }
        ]
      }
    },
    {
      "name": "DC303 Domain Branding - Workstation Wallpaper",
      "id": null,
      "backupPath": null,
      "description": "DC303 corporate desktop wallpaper for all domain workstations",
      "settings": {
        "user": [
          {
            "key": "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System",
            "valueName": "Wallpaper",
            "value": "\\\\dc303.cdx.lab\\NETLOGON\\Images\\dc303-desktop-wallpaper.jpg",
            "type": "String"
          },
          {
            "key": "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System",
            "valueName": "WallpaperStyle",
            "value": "4",
            "type": "String"
          },
          {
            "key": "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\ActiveDesktop",
            "valueName": "NoChangingWallPaper",
            "value": 1,
            "type": "DWord"
          }
        ]
      }
    }
  ],

