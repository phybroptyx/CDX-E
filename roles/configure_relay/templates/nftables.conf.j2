#!/usr/sbin/nft -f
# /etc/nftables.conf — CDX-RELAY firewall
# Generated by Ansible configure_relay role. DO NOT EDIT MANUALLY.
# Re-rendered by configure_relay on assign_nics and release_nics.

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established and related connections
        ct state established,related accept

        # Allow loopback
        iif lo accept

        # Allow SSH on management interface (from ACN)
        iif {{ relay_mgmt_iface }} tcp dport 22 accept

        # Allow SOCKS5 proxy connections (from ACN)
        iif {{ relay_mgmt_iface }} tcp dport {{ socks5_port }} accept

        # Drop all other input
    }

    chain forward {
        type filter hook forward priority 0; policy accept;

        # Allow established/related forwarding
        ct state established,related accept

        # Inter-segment isolation — exercise NICs cannot forward directly to
        # each other. Traffic must leave via the management or CDX-I interface.
        # This prevents pivot: a compromised Enterprise host cannot directly
        # reach the SOC segment or Red Team segment through the relay.
        # relay_nic_assignments[*].iface is set by assign_nics after hot-plug discovery.
{% if relay_nic_assignments | length > 1 %}
{% for nic_a in relay_nic_assignments %}
{% for nic_b in relay_nic_assignments %}
{% if nic_a.slot != nic_b.slot %}
        iif {{ nic_a.iface }} oif {{ nic_b.iface }} drop
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}

table inet nat {
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;

        # Masquerade traffic forwarded through the CDX-I uplink
        oif {{ relay_cdxi_iface }} masquerade
    }
}
