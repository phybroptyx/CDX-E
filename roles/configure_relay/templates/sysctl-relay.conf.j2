# /etc/sysctl.d/99-cdx-relay.conf — CDX-RELAY sysctl settings
# Generated by Ansible configure_relay role. DO NOT EDIT MANUALLY.

# Enable IPv4 forwarding (required for routing between exercise segments)
net.ipv4.ip_forward = 1

# Disable reverse path filtering.
# Exercise NICs carry asymmetric routing (traffic enters eth2, replies exit eth0)
# and strict rp_filter would silently drop these packets.
net.ipv4.conf.all.rp_filter = 0
net.ipv4.conf.default.rp_filter = 0
