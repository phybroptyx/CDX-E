# /etc/danted.conf — CDX-RELAY SOCKS5 proxy (dante-server)
# Generated by Ansible configure_relay role. DO NOT EDIT MANUALLY.
#
# Listens on {{ socks5_bind_ip }}:{{ socks5_port }}
# Ansible WinRM connections are proxied through this for exercise Windows VMs.

logoutput: syslog

# Internal interface — where clients connect (ACN management network)
internal: {{ socks5_bind_ip }} port = {{ socks5_port }}

# External interfaces — outbound paths to exercise segments
external: eth0
external: {{ relay_cdxi_iface }}
{% for nic in relay_nic_assignments %}
external: eth{{ nic.slot }}
{% endfor %}

# Authentication: none (relay is only reachable from ACN on Layer0)
socksmethod: none

# Accept connections from any client (ACN is the only network with access)
client pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: connect disconnect
}

# Forward all TCP connections without authentication
socks pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    protocol: tcp
    socksmethod: none
}
