# /etc/network/interfaces — CDX-RELAY
# Generated by Ansible configure_relay role. DO NOT EDIT MANUALLY.

source /etc/network/interfaces.d/*

auto lo
iface lo inet loopback

# eth0 — Layer0 management (static)
# Ansible controller (ACN) connects here for relay management and ProxyJump
auto eth0
iface eth0 inet static
    address {{ relay_management_ip }}/{{ relay_management_cidr }}
    gateway {{ relay_management_gw }}

# eth1 — CDX-I EQIX4 uplink (static)
# Traffic from exercise segments destined for CDX-I routes through here
auto {{ relay_cdxi_iface }}
iface {{ relay_cdxi_iface }} inet static
    address {{ relay_cdxi_ip }}/{{ relay_cdxi_cidr }}

# eth2-4 — Exercise segment bridges (dynamic)
# These interfaces are NOT defined here.
# They are hot-attached via Proxmox API and configured by
# configure_relay assign_nics during exercise deployment.
