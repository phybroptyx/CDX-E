# =============================================================================
# Terraform VM Configuration — Scenario VMs
# Exercise : {{ scenario.exercise.name }}
# Auto-generated by CDX-E Ansible Pipeline — do not edit manually.
# =============================================================================

{% for vm in _tf_vms %}
{%- set _vm_node = vm.proxmox.node | default(scenario.proxmox.node) %}
{%- if template_registry[vm.template].qnap_direct | default(false) %}
{%- set _clone_vmid = template_registry[vm.template].id | int %}
{%- set _clone_node = template_node %}
{%- else %}
{%- set _clone_vmid = template_registry[vm.template].id | int + proxmox_node_template_offset[_vm_node] | int %}
{%- set _clone_node = _vm_node %}
{%- endif %}
{#- ── Description metadata ─────────────────────────────────────────────────── #}
{#- Role label: map ansible_group to a human-readable role name #}
{%- set _role_map = {
      'domain_controllers': 'Domain Controller',
      'servers':            'Member Server',
      'sql_servers':        'SQL Server',
      'exchange_servers':   'Exchange Server',
      'workstations':       'Workstation',
      'routers':            'Router',
      'relay':              'Relay'
    } %}
{%- set _role_label = _role_map.get(vm.ansible_group, vm.ansible_group | replace('_', ' ') | title) %}
{#- OS display name from template_registry #}
{%- set _os_name = template_registry[vm.template].os | default(vm.template) %}
{#- IP address: static if cloud_init.ip defined, else DHCP #}
{%- if vm.cloud_init is defined and vm.cloud_init.ip is defined %}
{%-   set _ip_display = vm.cloud_init.ip ~ '/' ~ vm.cloud_init.cidr %}
{%- else %}
{%-   set _ip_display = 'DHCP' %}
{%- endif %}
{#- Domain and FQDN: domain-joined VMs get domain name; routers/relay get N/A #}
{%- if vm.ansible_group in ['routers', 'relay'] %}
{%-   set _domain_display = 'N/A' %}
{%-   set _fqdn_display   = vm.name | lower %}
{%- else %}
{%-   set _domain_display = scenario.domain.name %}
{%-   set _fqdn_display   = vm.name | lower ~ '.' ~ scenario.domain.name %}
{%- endif %}
{#- AD Site: find which configured site subnet contains this VM's IP.                      #}
{#- Jinja2 loop-scope limitation: inner set does not propagate out; use namespace() trick. #}
{%- set _ns = namespace(site_display='N/A') %}
{%- if vm.cloud_init is defined and vm.cloud_init.ip is defined and scenario.domain.sites is defined %}
{%-   set _vm_prefix = vm.cloud_init.ip.split('.')[:3] | join('.') %}
{%-   for site in scenario.domain.sites %}
{%-     for subnet in site.subnets | default([]) %}
{%-       if _ns.site_display == 'N/A' %}
{%-         set _site_prefix = subnet.split('/')[0].split('.')[:3] | join('.') %}
{%-         if _vm_prefix == _site_prefix %}
{%-           set _ns.site_display = site.name %}
{%-         endif %}
{%-       endif %}
{%-     endfor %}
{%-   endfor %}
{%- endif %}
{%- set _site_display = _ns.site_display %}
# ── {{ vm.name }} ({{ vm.template }}) ──────────────────────────────────────────
resource "proxmox_virtual_environment_vm" "{{ vm.name | lower | regex_replace('[^a-z0-9]', '_') }}" {
  name      = "{{ vm.name }}"
  node_name = "{{ _vm_node }}"
  vm_id     = {{ vm.vmid }}
  pool_id   = "EX_{{ scenario.exercise.name }}"

  description = <<-EOT
    # {{ vm.name }}
    ### **Role:** {{ _role_label }}
    ### **Name:** {{ _fqdn_display }}
    ### **Operating System:** {{ _os_name }}
    ### **IP Address:** {{ _ip_display }}
    ### **Domain:** {{ _domain_display }}
    ### **Active Directory Site:** {{ _site_display }}
    ### **Vulnerabilities:** N/A
  EOT

  clone {
    vm_id     = {{ _clone_vmid }}
    node_name = "{{ _clone_node }}"
    full      = false
    retries   = 3
  }

  cpu {
    cores   = {{ vm.resources.cores }}
    sockets = {{ vm.resources.sockets | default(1) }}
    type    = "x86-64-v2-AES"
  }

  memory {
    dedicated = {{ vm.resources.memory_mb }}
  }
{% if vm.ansible_group == 'workstations' %}

  # Workstations: net0 directly on exercise bridge — no Layer0 bootstrap.
  # Clients receive IP from the domain DHCP server (active after Phase 6).
  # No NIC migration required; lifecycle does NOT ignore network_device.
  network_device {
    # net0 — {{ vm.network.additional_nics[0].bridge }} (exercise bridge; DHCP from domain)
    bridge   = "{{ vm.network.additional_nics[0].bridge }}"
    model    = "{{ vm.network.additional_nics[0].model | default('virtio') }}"
    firewall = false
  }

{% elif template_registry[vm.template].os_type in ['windows', 'linux'] and vm.ansible_group == 'domain_controllers' %}

  # Domain controllers: Bootstrap NIC on Layer0 — DCs boot before the domain
  # DHCP server is active. Ansible configures the static exercise IP via
  # guest-exec, then migrates this NIC to the exercise bridge via Proxmox API.
  # lifecycle.ignore_changes prevents Terraform from reverting the migration.
  network_device {
    # net0 — Layer0 bootstrap (Ansible migrates to {{ vm.network.additional_nics[0].bridge | default('exercise bridge') }})
    bridge   = "{{ proxmox_layer0_bridge }}"
    model    = "virtio"
    firewall = false
  }

{% elif template_registry[vm.template].os_type in ['windows', 'linux'] %}

  # Member servers: net0 directly on exercise bridge — by Phase 4.5, the domain
  # DHCP server is active and serves addresses on this bridge. No Layer0
  # bootstrap or NIC migration required. Static exercise IP is still configured
  # via guest-exec after the DHCP address is confirmed.
  network_device {
    # net0 — {{ vm.network.additional_nics[0].bridge }} (exercise bridge; DHCP from domain then static via guest-exec)
    bridge   = "{{ vm.network.additional_nics[0].bridge }}"
    model    = "{{ vm.network.additional_nics[0].model | default('virtio') }}"
    firewall = false
  }

{% elif template_registry[vm.template].os_type == 'vyos' %}

  # VyOS: net0 starts on Layer0 for SSH bootstrap. configure_networking SSHes to
  # the Layer0 DHCP IP, stages the full VyOS config file, then applies it via
  # nohup vbash (commit reconfigures eth0, breaking the SSH session — expected).
  # After apply, net0 is migrated from Layer0 to additional_nics[0].bridge via
  # Proxmox API. lifecycle.ignore_changes prevents Terraform from reverting the
  # bridge migration on subsequent applies.
  network_device {
    # net0 — Layer0 bootstrap (Ansible migrates to {{ vm.network.additional_nics[0].bridge | default('exercise bridge') }})
    bridge   = "{{ proxmox_layer0_bridge }}"
    model    = "virtio"
    firewall = false
  }

{% for nic in vm.network.additional_nics[1:] %}
  network_device {
    # net{{ loop.index }} — {{ nic.bridge }}
    bridge   = "{{ nic.bridge }}"
    model    = "{{ nic.model | default('virtio') }}"
    firewall = {{ 'true' if nic.firewall | default(false) | bool else 'false' }}
  }
{% endfor %}

{% elif vm.network is defined and vm.network.additional_nics | default([]) | length > 0 %}

  # Multi-NIC VMs (non-VyOS): all exercise NICs specified directly.
{% for nic in vm.network.additional_nics %}
  network_device {
    # net{{ loop.index0 }} — {{ nic.bridge }}
    bridge   = "{{ nic.bridge }}"
    model    = "{{ nic.model | default('virtio') }}"
    firewall = {{ 'true' if nic.firewall | default(false) | bool else 'false' }}
  }
{% endfor %}
{% endif %}

  # All VMs clone powered off. Terraform is a pure provisioner (clone + hardware config).
  # The bpg/proxmox provider blocks until the QEMU guest agent responds when started=true,
  # which can take 8-15 minutes for Windows Sysprep on a fresh clone — unacceptable for
  # pipeline speed. Ansible (vm_power_management) drives all power-on operations via the
  # Proxmox API in dependency order:
  #   Phase 2b   : routers + domain controllers (first VMs up)
  #   Phase 3    : VyOS router configuration (routers exercise-ready, DCs proceed)
  #   Phase 4b   : member servers (after AD domain is built)
  #   Phase 6a   : workstations (after domain DHCP scope is active)
  started = false

  # Use standard VGA display — avoids inheriting SPICE/QXL from the Packer template.
  vga {
    type = "std"
  }

  lifecycle {
    # domain_controllers + VyOS: ignore network_device — Ansible migrates net0 to exercise bridge.
    # Member servers: NIC starts on exercise bridge at clone time, no migration.
    # Workstations: NIC config is fixed at clone time, no migration needed.
    ignore_changes = [started{% if vm.ansible_group == 'domain_controllers' or template_registry[vm.template].os_type == 'vyos' %}, network_device{% endif %}]
  }
}
{% endfor %}
