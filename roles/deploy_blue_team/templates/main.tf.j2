# =============================================================================
# Terraform VM Configuration — Blue Team / SOC Infrastructure
# Exercise : {{ scenario.exercise.name }}
# Layout   : {{ soc_layout_name }}
# Auto-generated by CDX-E Ansible Pipeline — do not edit manually.
# =============================================================================

{% for vm in _tf_vms %}
{%- set _vm_node = vm.proxmox.node | default(scenario.proxmox.node) %}
{%- if template_registry[vm.template].qnap_direct | default(false) %}
{%- set _clone_vmid = template_registry[vm.template].id | int %}
{%- set _clone_node = template_node %}
{%- else %}
{%- set _clone_vmid = template_registry[vm.template].id | int + proxmox_node_template_offset[_vm_node] | int %}
{%- set _clone_node = _vm_node %}
{%- endif %}
# ── {{ vm.name }} ({{ vm.template }}) ──────────────────────────────────────────
resource "proxmox_virtual_environment_vm" "{{ vm.name | lower | regex_replace('[^a-z0-9]', '_') }}" {
  name      = "{{ vm.name }}"
  node_name = "{{ _vm_node }}"
  vm_id     = {{ vm.vmid }}
  pool_id   = "EX_{{ scenario.exercise.name }}"

  clone {
    vm_id     = {{ _clone_vmid }}
    node_name = "{{ _clone_node }}"
    full      = false
    retries   = 3
  }

  cpu {
    cores   = {{ vm.resources.cores }}
    sockets = {{ vm.resources.sockets | default(1) }}
    type    = "x86-64-v2-AES"
  }

  memory {
    dedicated = {{ vm.resources.memory_mb }}
  }
{% if template_registry[vm.template].os_type in ['windows', 'linux'] %}

  # Bootstrap NIC on Layer0 — VM receives DHCP IP for initial WinRM/SSH access.
  # Ansible configures the static exercise IP via WinRM, then migrates this NIC
  # to the exercise bridge via Proxmox API. lifecycle.ignore_changes prevents
  # Terraform from reverting Ansible's NIC migration on subsequent applies.
  network_device {
    # net0 — Layer0 bootstrap (Ansible migrates to {{ vm.network.additional_nics[0].bridge | default('exercise bridge') }})
    bridge   = "{{ proxmox_layer0_bridge }}"
    model    = "virtio"
    firewall = false
  }

{% elif vm.network is defined and vm.network.additional_nics | default([]) | length > 0 %}

  # VyOS / multi-NIC VMs: all exercise NICs specified directly.
  # Bootstrap is via QEMU guest-exec (vbash/iproute2) — no Layer0 NIC needed.
{% for nic in vm.network.additional_nics %}
  network_device {
    # net{{ loop.index0 }} — {{ nic.bridge }}
    bridge   = "{{ nic.bridge }}"
    model    = "{{ nic.model | default('virtio') }}"
    firewall = {{ 'true' if nic.firewall | default(false) | bool else 'false' }}
  }
{% endfor %}
{% endif %}

  # VMs are left powered-off after deployment.
  # The vm_power_management role handles power-on after inventory_refresh.
  started = false

  # Use standard VGA display — avoids inheriting SPICE/QXL from the Packer template.
  vga {
    type = "std"
  }

  lifecycle {
    # ignore network_device for Windows/Linux — Ansible migrates net0 to exercise bridge.
    ignore_changes = [started{% if template_registry[vm.template].os_type in ['windows', 'linux'] %}, network_device{% endif %}]
  }
}
{% endfor %}
