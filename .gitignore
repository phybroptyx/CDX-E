# =============================================================================
# CDX-E .gitignore
# =============================================================================

# Generated files (auto-created by generate_structure.ps1)
EXERCISES/*/structure.json

# PowerShell artifacts
*.psm1.bak
*.ps1.bak

# Ansible artifacts
*.retry
.ansible/
inventory/*.cache

# Logs
*.log
logs/

# Windows artifacts
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets — actual credentials file (use secrets.example/credentials.yml as template)
# Encrypt with: ansible-vault encrypt secrets/credentials.yml
secrets/credentials.yml
Secrets/credentials.yml

# Terraform state files — contain sensitive IPs, VMIDs, and embedded API tokens
EXERCISES/*/terraform/terraform.tfstate
EXERCISES/*/terraform/*.tfstate.backup
EXERCISES/*/terraform_red_team/terraform.tfstate
EXERCISES/*/terraform_red_team/*.tfstate.backup
EXERCISES/*/terraform_blue_team/terraform.tfstate
EXERCISES/*/terraform_blue_team/*.tfstate.backup
*.tfstate
*.tfstate.backup

# Generated dynamic inventory (written by inventory_refresh role)
inventory/exercise_hosts.yml

# Scenario instruction files (ad-hoc session context)
*_instructions.*

# Scratch / working files
scratch/
temp/
tmp/
